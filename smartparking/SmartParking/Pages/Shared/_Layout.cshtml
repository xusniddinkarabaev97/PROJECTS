<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Биллинг Парковки</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartParking.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-page="/Billing/Index">
                    &#128663; Биллинг Парковки
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                                                    <a class="nav-link text-light" asp-page="/Billing/Index">Панель</a>
                                                </li>
                                                <li class="nav-item">
                                                    <a class="nav-link text-light" asp-page="/Billing/Transactions">Транзакции</a>
                                                </li>
                                                <li class="nav-item">
                                                    <a class="nav-link text-light" asp-page="/Billing/QrCode">QR-код</a>
                                                </li>
                                                <li class="nav-item">
                                                    <a class="nav-link text-light" asp-page="/Index">Главная</a>
                                                </li>
                        <li class="nav-item">
                                                    <a class="nav-link text-light" asp-page="/Privacy">Инфо</a>
                                                </li>
                                                <li class="nav-item">
                                                    <a class="nav-link text-light" href="/swagger">API</a>
                                                </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light">
        <div class="container-fluid">
            &copy; 2026 - Биллинг Парковки &middot; Система учёта и распределения платежей
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
