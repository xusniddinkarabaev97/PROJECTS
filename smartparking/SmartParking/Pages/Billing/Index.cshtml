@page
@model SmartParking.Pages.Billing.IndexModel
@{
    ViewData["Title"] = "Биллинг Парковки";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
            <i class="bi bi-receipt"></i> Панель Биллинга Парковки
        </h1>
        <span class="badge bg-success fs-6">Активна</span>
    </div>

    @* СТАТИСТИКА *@
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card border-primary border-2 h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1">Транзакций всего</p>
                            <h2 class="mb-0 fw-bold">@Model.TotalTransactions</h2>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded-3 p-2">
                            <span style="font-size:1.5rem;">&#128179;</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-success border-2 h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1">Доход сегодня</p>
                            <h2 class="mb-0 fw-bold">@Model.TodayRevenue.ToString("N2") ₽</h2>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-3 p-2">
                            <span style="font-size:1.5rem;">&#128176;</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-info border-2 h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1">Компании</p>
                            <h2 class="mb-0 fw-bold">@Model.TotalCompanies</h2>
                        </div>
                        <div class="bg-info bg-opacity-10 rounded-3 p-2">
                            <span style="font-size:1.5rem;">&#127970;</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-warning border-2 h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1">Станции</p>
                            <h2 class="mb-0 fw-bold">@Model.TotalStations</h2>
                        </div>
                        <div class="bg-warning bg-opacity-10 rounded-3 p-2">
                            <span style="font-size:1.5rem;">&#9981;</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* БЫСТРЫЕ ДЕЙСТВИЯ *@
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header fw-semibold">
                    Быстрые действия
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-page="/Billing/Transactions" class="btn btn-outline-success">
                                                    &#128179; Транзакции
                                                </a>
                                                <a asp-page="/Billing/QrCode" class="btn btn-outline-danger">
                                                    &#128260; QR-код
                                                </a>
                                                <a href="/swagger" class="btn btn-outline-primary" target="_blank">
                                                    API Swagger
                                                </a>
                        <a href="/api/Transactions" class="btn btn-outline-success">
                            Все транзакции (API)
                        </a>
                        <a href="/api/Companies" class="btn btn-outline-info">
                            Компании (API)
                        </a>
                        <a href="/api/Clients" class="btn btn-outline-warning">
                            Клиенты (API)
                        </a>
                        <a href="/api/Stations" class="btn btn-outline-secondary">
                            Станции (API)
                        </a>
                        <a href="/api/Plans" class="btn btn-outline-dark">
                            Тарифные планы (API)
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ПОСЛЕДНИЕ ТРАНЗАКЦИИ *@
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                    <span>Последние транзакции парковки</span>
                    <span class="badge bg-secondary">последние 10</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Клиент</th>
                                    <th>Сумма</th>
                                    <th>Статус оплаты</th>
                                    <th>Тип</th>
                                    <th>Дата</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentTransactions.Count == 0)
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            Нет данных о транзакциях
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var t in Model.RecentTransactions)
                                    {
                                        var statusClass = t.PaymentStatus switch
                                        {
                                            "Paid" => "success",
                                            "New" => "warning",
                                            "Cancelled" => "danger",
                                            _ => "secondary"
                                        };
                                        <tr>
                                            <td class="text-muted">@t.Id</td>
                                            <td class="fw-medium">@t.ClientName</td>
                                            <td class="fw-bold">@t.TotalSum.ToString("N2") ₽</td>
                                            <td>
                                                <span class="badge bg-@statusClass">@t.PaymentStatus</span>
                                            </td>
                                            <td>
                                                <span class="badge bg-dark">@t.Status</span>
                                            </td>
                                            <td class="text-muted small">@t.FilledAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ФУТЕР ИНФОРМАЦИЯ *@
    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h5>@Model.TotalClients</h5>
                    <small class="text-muted">Клиентов в системе</small>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <p class="mb-0 text-muted">
                        Система биллинга парковки v1.0 &middot;
                        Управление транзакциями, станциями и тарифными планами
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
