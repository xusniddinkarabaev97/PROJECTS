{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "MassTransit": "Debug"
      }
    }
  },
  "JwtSettings": {
    "Authority": "https://localhost:5001",
    "Audience": "billing-api",
    "IssuerSigningKey": "ThisIsMySuperSecretKeyForDev12345678!!",
    "TokenValidationParameters": {
      "ValidateIssuer": true,
      "ValidateAudience": true,
      "ValidateLifetime": true,
      "ValidateIssuerSigningKey": true,
      "ClockSkew": "00:00:30"
    },
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationHours": 24
  },
  "MtlsSettings": {
    "ClientCertificatePath": "",
    "ClientCertificatePassword": "",
    "ServerCertificateValidation": {
      "AllowUntrustedRoot": true,
      "CheckCertificateRevocation": false,
      "RequiredSubjectPatterns": []
    }
  },
  "RateLimitingSettings": {
    "DefaultPolicy": {
      "PermitLimit": 1000,
      "WindowSeconds": 60,
      "QueueProcessingOrder": "OldestFirst",
      "QueueLimit": 10
    },
    "ContragentPolicies": {
      "high_volume_partner": {
        "PermitLimit": 5000,
        "WindowSeconds": 60
      },
      "low_volume_partner": {
        "PermitLimit": 300,
        "WindowSeconds": 60
      }
    }
  },
  "WebhookSettings": {
    "SignatureHeaderName": "X-Signature-256",
    "SignatureAlgorithm": "HMACSHA256",
    "TimestampHeaderName": "X-Webhook-Timestamp",
    "ToleranceSeconds": 300,
    "ContragentSecrets": {
      "payment_gateway_uzcard": "dev-secret-uzcard-0123456789abcdef",
      "payment_gateway_humo": "dev-secret-humo-fedcba9876543210"
    }
  },
  "ReplayProtectionSettings": {
    "NonceHeaderName": "X-Nonce",
    "TimestampHeaderName": "X-Timestamp",
    "MaxAgeMinutes": 1,
    "CachePrefix": "replay:nonce:"
  },
  "RabbitMqSettings": {
    "Enabled": false,
    "Host": "rabbitmq://localhost",
    "Username": "guest",
    "Password": "guest",
    "MessageTtl": "01:00:00",
    "RetryPolicy": {
      "Intervals": ["00:00:03", "00:00:10", "00:00:30"],
      "MaxRetryCount": 3
    },
    "CircuitBreaker": {
      "TrackingPeriod": "00:01:00",
      "TripThreshold": 15,
      "ActiveThreshold": 5,
      "ResetInterval": "00:00:15"
    },
    "DeadLetterQueue": {
      "Enabled": true,
      "Suffix": ".dlq-dev",
      "MessageRetentionDays": 7
    },
    "PrefetchCount": 4,
    "AutoAck": false
  },
  "AuditLogSettings": {
    "LogDirectory": "logs/audit",
    "RetentionDays": 7,
    "EncryptLogs": false,
    "EncryptionKey": "",
    "LogLevel": "Debug",
    "IncludeRequestBody": true,
    "IncludeResponseBody": true,
    "MaxRequestBodyLogSize": 8192
  },
  "AppBaseUrl": "http://localhost:5173",
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "billing-dev:"
  },
  "AllowedHosts": "*"
}
