{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "GzsBilling": "Debug"
    }
  },
  "ConnectionStrings": {
    "GzsBillingWrite": "Host=localhost;Port=5433;Database=gzs_billing;Username=postgres;Password=postgres",
    "RabbitMQ": "amqp://guest:guest@localhost:5672"
  },
  "Billing": {
    "RabbitMq": {
      "ExchangeName": "gzs.billing.exchange",
      "TransactionCompletedRoutingKey": "tranzaksiya.completed",
      "SverkaQueueName": "gzs.billing.sverka.queue",
      "ClientProvidedName": "gzs-billing-sverka",
      "ConsumerPrefetchCount": 10
    },
    "AbcBank": {
      "BaseUrl": "https://api.abcbank.uz",
      "TimeoutSeconds": 30
    }
  }
}
